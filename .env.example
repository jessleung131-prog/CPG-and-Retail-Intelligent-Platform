# ─── GCP ────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# ─── BigQuery ────────────────────────────────────────────────────────────────
BQ_DATASET_RAW=cpg_raw
BQ_DATASET_STAGING=cpg_staging
BQ_DATASET_MART=cpg_mart
BQ_DATASET_ML=cpg_ml
BQ_DATASET_MONITORING=cpg_monitoring

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=replace-with-a-strong-secret

# ─── Claude API (for insights + deck generation) ────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-opus-4-6

# ─── Synthetic data ──────────────────────────────────────────────────────────
SYNTHETIC_START_DATE=2023-01-01
SYNTHETIC_END_DATE=2024-12-31
SYNTHETIC_SEED=42

# ─── Alerting ────────────────────────────────────────────────────────────────
# Optional: Slack webhook for monitoring alerts
SLACK_WEBHOOK_URL=
